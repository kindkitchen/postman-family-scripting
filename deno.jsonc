{
  "nodeModulesDir": "manual",
  "tasks": {
    "clean": {
      "description": "Remove build artifacts",
      "command": "rm -fr dist ./magic.js"
    },
    "transpile": {
      "description": "ts to js",
      "command": "npx tsc",
      "dependencies": [
        "clean"
      ]
    },
    "build": {
      "description": "Build all project codebase into single file",
      "command": "npx pkgroll",
      "dependencies": [
        "transpile"
      ]
    },
    "format": {
      "description": "Fix formatting",
      "command": "deno fmt",
      "dependencies": [
        "build"
      ]
    },
    "start": {
      "description": "Do all required stuff to generate fresh actual version of magic.js",
      "command": "cp ./dist/index.js ./magic.js",
      "dependencies": [
        "format"
      ]
    },
    "gitam": {
      "description": "Quick git commit",
      "command": "git add -A && git commit",
      "dependencies": [
        "format"
      ]
    },
    "pr": {
      "description": "Shortcut to create PR and merge dev branch into main",
      "command": "git push origin dev && gh pr create --fill-verbose && gh pr merge --auto --merge",
      "dependencies": [
        "start",
        "gitam"
      ]
    }
  }
}
